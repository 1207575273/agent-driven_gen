# 母版默认配置(已随仓库提交, fork 后开箱即用, 想改哪项直接改这里)。
# 所有变量以 APP_ 为前缀; 优先级: 环境变量 > 本文件 > 代码默认。
#
# 【安全红线】本文件只放"无密钥的默认值"。真实密钥 / 生产专属值(库密码、API key 等)
#  一律用环境变量注入(K8s ConfigMap / Nacos / 部署平台), 禁止写进本文件提交!

APP_DATABASE_URL=sqlite+aiosqlite:///./dev.db
APP_API_PREFIX=/api

# 日志(嵌套键用双下划线):
APP_LOGGING__LEVEL=INFO
APP_LOGGING__SQL_ECHO=true
# 其余日志项有默认(一般不用改): dir / json_file / rotation_when / rotation_interval_hours / backup_count
# APP_LOGGING__ROTATION_INTERVAL_HOURS=8
# APP_LOGGING__BACKUP_COUNT=30

# CORS 放行来源(JSON 数组), 生产收窄:
# APP_CORS_ORIGINS=["https://your.domain"]
